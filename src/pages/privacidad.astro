---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getPrivacyPage } from "../lib/sanity.js";

type PrivacyPage = {
  title?: string;
  subtitle?: string;
  updatedAt?: string;
  body?: string;
};

const privacy: PrivacyPage | null = await getPrivacyPage();

const title = privacy?.title || "Aviso de privacidad";
const subtitle =
  privacy?.subtitle || "Aviso de privacidad para atencion y contacto de pacientes.";
const updatedAtLabel = privacy?.updatedAt
  ? new Date(`${privacy.updatedAt}T12:00:00`).toLocaleDateString("es-MX", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "22 de febrero de 2026";

const fallbackParagraphs = [
  "Este sitio solicita datos de contacto para responder dudas y gestionar citas. Los datos se usan para atencion al paciente, seguimiento de servicios y comunicacion relacionada con la solicitud.",
  "Los datos que se pueden solicitar incluyen nombre, telefono, servicio de interes, fecha y hora preferida, y notas opcionales de atencion.",
  "Los datos no se venden a terceros. Solo se comparten cuando sea necesario para operar el servicio, por ejemplo con plataformas de mensajeria, agenda, analitica tecnica u hospedaje web.",
  "Puedes solicitar acceso, correccion, actualizacion o eliminacion de tus datos contactando al consultorio por WhatsApp o telefono.",
  "La informacion se conserva solo durante el tiempo necesario para atender la solicitud, dar seguimiento al servicio y cumplir obligaciones aplicables.",
];

const paragraphs = String(privacy?.body || "")
  .split(/\n\s*\n/g)
  .map((p) => p.trim())
  .filter(Boolean);

const bodyParagraphs = paragraphs.length > 0 ? paragraphs : fallbackParagraphs;
---

<Layout title={`${title} | Podologos Via Morelos Tulpetlac`} description={subtitle}>
  <Header />

  <main class="mx-auto max-w-4xl px-4 py-10">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
    <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Ultima actualizacion: {updatedAtLabel}</p>

    <div class="mt-6 space-y-4 rounded-2xl border border-slate-200 bg-white p-6 text-sm leading-relaxed text-slate-700 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-300">
      {bodyParagraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  </main>

  <Footer />
</Layout>
