---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { clinic } from "../../config/clinic";
import { getBusinessInfo, getServices, getSpecialists } from "../../lib/sanity.js";
import { normalizeServiceSlug } from "../../utils/prefill";
import {
  buildContactMessage,
  buildWhatsAppUrl,
  resolveWhatsAppNumber,
  resolveWhatsAppReason,
} from "../../utils/whatsapp";

type ServiceItem = {
  title?: string;
  slug?: string | { current?: string };
  short?: string;
  duration?: string;
  priceFrom?: number;
  category?: string;
  leadSpecialistSlug?: string;
  whatsAppNumber?: string;
  whatsAppMessage?: string;
};

type SpecialistRoutingItem = {
  _id?: string;
  slug?: string;
  name?: string;
  specialty?: string;
  specialtyCategory?: string;
  whatsAppNumber?: string;
  whatsAppMessage?: string;
  useWhatsAppButton?: boolean;
};

const business = await getBusinessInfo();
const services: ServiceItem[] = (await getServices()) || [];
const specialists: SpecialistRoutingItem[] = (await getSpecialists()) || [];
const validSlugRe = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;

const generalWaNumber = resolveWhatsAppNumber(
  business?.whatsappCitasNumber,
  clinic.whatsappNumber
);
const specialistsWaNumber = resolveWhatsAppNumber(
  business?.whatsappSpecialistsNumber,
  generalWaNumber
);

const serviceCategories = [
  { key: "all", label: "Todas" },
  { key: "podologia", label: "Podologia" },
  { key: "psicologia", label: "Psicologia" },
  { key: "optica", label: "Optica" },
  { key: "quiropractica", label: "Quiropractica" },
  { key: "dentista", label: "Dentista" },
];

const specialistBySlug = new Map<string, SpecialistRoutingItem>();
for (const specialist of specialists) {
  const slug = String(specialist?.slug || specialist?._id || "").trim();
  if (!slug) continue;
  specialistBySlug.set(slug, specialist);
}

function moneyMXN(n: number | string | null | undefined) {
  const num = Number(n);
  if (Number.isNaN(num) || num <= 0) return "";
  try {
    return new Intl.NumberFormat("es-MX", {
      style: "currency",
      currency: "MXN",
      maximumFractionDigits: 0,
    }).format(num);
  } catch {
    return `$${num}`;
  }
}
---

<Layout title="Servicios | Podologos Via Morelos Tulpetlac">
  <Header />

  <main class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Servicios</h1>
    <p class="mt-2 text-slate-800 dark:text-slate-200">Conoce que incluye cada servicio y su precio desde.</p>

    {services.length === 0 && (
      <div class="mt-8 rounded-2xl border border-slate-200 bg-white/95 p-6 text-slate-600 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-300">
        Pronto compartiremos mas servicios. Mientras tanto, puedes agendar tu cita.
      </div>
    )}

    {services.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2" id="service-filters">
        {serviceCategories.map((cat, idx) => (
          <button
            type="button"
            data-service-filter={cat.key}
            class:list={["category-chip", idx === 0 && "category-chip--active"]}
          >
            {cat.label}
          </button>
        ))}
      </div>
    )}

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service: ServiceItem) => {
        const rawSlug =
          typeof service.slug === "string" ? service.slug : service.slug?.current;
        const cleanSlug = typeof rawSlug === "string" ? rawSlug.trim() : "";
        const hasValidSlug = validSlugRe.test(cleanSlug);
        const detailHref = hasValidSlug ? `/servicios/${cleanSlug}` : "/servicios";

        const serviceLabel = service.title || "Servicio";
        const serviceCategory = normalizeServiceSlug(
          service.category || service.title || cleanSlug
        );
        const servicePrice = Number(service.priceFrom || 0);

        const preferredSpecialistSlug =
          String(service.leadSpecialistSlug || "").trim();
        const routingSpecialist = preferredSpecialistSlug
          ? specialistBySlug.get(preferredSpecialistSlug)
          : undefined;
        const manualServiceWaNumber = String(service.whatsAppNumber || "").trim();
        const manualServiceWaMessage = String(service.whatsAppMessage || "").trim();

        const agendarParams = new URLSearchParams();
        if (serviceCategory) agendarParams.set("service", serviceCategory);
        if (preferredSpecialistSlug) agendarParams.set("specialist", preferredSpecialistSlug);
        if (manualServiceWaNumber) agendarParams.set("waNumber", manualServiceWaNumber);
        if (manualServiceWaMessage) agendarParams.set("waMessage", manualServiceWaMessage);
        if (serviceLabel) agendarParams.append("services", serviceLabel);
        if (serviceLabel) agendarParams.append("waNumbers", manualServiceWaNumber || "__none__");
        if (serviceLabel) agendarParams.append("waMessages", manualServiceWaMessage || "__none__");
        if (servicePrice > 0) {
          agendarParams.set("approxTotal", String(Math.round(servicePrice)));
        }
        const agendarHref = agendarParams.toString()
          ? `/agendar?${agendarParams.toString()}`
          : "/agendar";

        const useSpecialistWa = !manualServiceWaNumber && routingSpecialist?.useWhatsAppButton !== false;
        const waReasonTemplate = manualServiceWaMessage
          ? manualServiceWaMessage
          : useSpecialistWa
            ? routingSpecialist?.whatsAppMessage ||
              business?.whatsappSpecialistsMessage ||
              business?.whatsappGeneralMessage
            : business?.whatsappGeneralMessage;
        const waTargetNumber = resolveWhatsAppNumber(
          manualServiceWaNumber,
          useSpecialistWa ? routingSpecialist?.whatsAppNumber : "",
          specialistsWaNumber,
          generalWaNumber
        );
        const waHref = buildWhatsAppUrl(
          buildContactMessage({
            service: serviceLabel,
            reason: resolveWhatsAppReason(
              waReasonTemplate,
              useSpecialistWa
                ? "Quiero informacion y agendar {servicio} con {especialista}."
                : "Quiero informacion y agendar este servicio.",
              {
                specialist: routingSpecialist?.name || "especialista disponible",
                service: serviceLabel,
                business: business?.name || clinic.name,
                problem: business?.whatsappQuickProblemDefault || "",
              }
            ),
          }),
          waTargetNumber
        );

        return (
          <article
            data-service-card
            data-category={serviceCategory || "general"}
            class="card-surface flex h-full flex-col rounded-3xl p-6 shadow-sm"
          >
            <div class="flex-1">
              <h2 class="text-lg font-semibold">{serviceLabel}</h2>
              {service.short && (
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{service.short}</p>
              )}

              <div class="mt-4 flex flex-wrap gap-2 text-xs text-slate-600 dark:text-slate-300">
                {service.duration && (
                  <span class="rounded-full border border-slate-200 px-3 py-1 dark:border-slate-800">
                    Duracion {service.duration}
                  </span>
                )}
                {!!moneyMXN(service.priceFrom) && (
                  <span class="rounded-full border border-slate-200 px-3 py-1 dark:border-slate-800">
                    Desde {moneyMXN(service.priceFrom)}
                  </span>
                )}
              </div>
            </div>

            <div class="mt-6 grid grid-cols-2 gap-2 pt-1">
              <a class="btn-base btn-primary w-full" href={detailHref}>
                Ver detalle
              </a>
              <a class="btn-base btn-secondary w-full" href="/precios">
                Precios
              </a>
              <a class="btn-base btn-secondary col-span-2 w-full" href={agendarHref}>
                Agendar este servicio
              </a>
              <a
                class="btn-base btn-secondary col-span-2 w-full"
                href={waHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                WhatsApp
              </a>
            </div>
          </article>
        );
      })}
    </div>

    <p
      id="services-empty"
      class="mt-6 hidden rounded-2xl border border-slate-200 bg-white p-4 text-left text-sm text-slate-600 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-300"
    >
      No hay servicios en esa categoria todavia.
    </p>
  </main>

  <Footer />
</Layout>

<script is:inline>
  const serviceFilterButtons = Array.from(document.querySelectorAll("[data-service-filter]"));
  const serviceCards = Array.from(document.querySelectorAll("[data-service-card]"));
  const servicesEmpty = document.getElementById("services-empty");
  let activeServiceFilter = "all";

  const animateFilteredItems = (items) => {
    items.forEach((item, index) => {
      item.classList.remove("filter-item-in", "filter-item-in-slide");
      item.style.animationDelay = `${Math.min(index, 10) * 45}ms`;
      void item.offsetWidth;
      item.classList.add("filter-item-in-slide");
    });
  };

  const updateServiceFilterUI = () => {
    serviceFilterButtons.forEach((btn) => {
      const isActive = btn.dataset.serviceFilter === activeServiceFilter;
      btn.classList.toggle("category-chip--active", isActive);
    });
  };

  const applyServiceFilter = (animate = false) => {
    let visibleCount = 0;
    const visibleCards = [];

    serviceCards.forEach((card) => {
      const category = card.dataset.category || "general";
      const visible = activeServiceFilter === "all" || category === activeServiceFilter;
      card.classList.toggle("hidden", !visible);
      if (visible) {
        visibleCount += 1;
        visibleCards.push(card);
      }
    });

    if (servicesEmpty) servicesEmpty.classList.toggle("hidden", visibleCount > 0);
    if (animate) requestAnimationFrame(() => animateFilteredItems(visibleCards));
  };

  serviceFilterButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeServiceFilter = btn.dataset.serviceFilter || "all";
      updateServiceFilterUI();
      applyServiceFilter(true);
    });
  });

  updateServiceFilterUI();
  applyServiceFilter(false);
</script>
