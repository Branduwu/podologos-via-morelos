---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getSiteAnnouncements } from "../lib/sanity.js";

type Announcement = {
  _id?: string;
  title?: string;
  publishDate?: string;
  body?: string;
};

const cmsItems: Announcement[] = (await getSiteAnnouncements()) || [];
const fallbackItems = [
  {
    title: "Nuevo canal de atencion por WhatsApp",
    date: "22/02/2026",
    body: "Ya puedes enviar tu solicitud de cita directamente desde cualquier pagina del sitio usando el boton flotante.",
  },
  {
    title: "Seccion de FAQ actualizada",
    date: "22/02/2026",
    body: "Publicamos preguntas frecuentes por categorias para resolver dudas antes de agendar.",
  },
];

const items =
  cmsItems.length > 0
    ? cmsItems.map((item) => ({
        id: item._id || `${item.title || "item"}-${item.publishDate || ""}`,
        title: item.title || "Comunicado",
        date: item.publishDate
          ? new Date(`${item.publishDate}T12:00:00`).toLocaleDateString("es-MX")
          : "-",
        body: item.body || "",
      }))
    : fallbackItems.map((item, index) => ({
        id: `fallback-${index}`,
        title: item.title,
        date: item.date,
        body: item.body,
      }));
---

<Layout title="Comunicados | Podologos Via Morelos Tulpetlac" description="Noticias y avisos del consultorio.">
  <Header />

  <main class="mx-auto max-w-4xl px-4 py-10">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Comunicados</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-300">Aqui compartimos avisos y actualizaciones para pacientes.</p>

    <div class="mt-6 space-y-4">
      {items.map((item) => (
        <article class="rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-950" data-announcement-id={item.id}>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-slate-500 dark:text-slate-400">{item.date}</p>
          <h2 class="mt-2 text-xl font-bold">{item.title}</h2>
          <p class="mt-2 text-sm text-slate-700 dark:text-slate-300">{item.body}</p>
        </article>
      ))}
    </div>
  </main>

  <Footer />
</Layout>
