---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { clinic } from "../config/clinic";
import { getAboutSection, getBusinessInfo, getServices, getSpecialists } from "../lib/sanity.js";
import {
  buildContactMessage,
  buildWhatsAppUrl,
  resolveWhatsAppNumber,
  resolveWhatsAppReason,
} from "../utils/whatsapp";

type AboutSection = {
  title?: string;
  intro?: string;
  secondary?: string;
  keyPoints?: string[];
  specialistsTitle?: string;
  specialistsSubtitle?: string;
  servicesTitle?: string;
  servicesSubtitle?: string;
  mainImageUrl?: string;
  galleryImageUrls?: string[];
  galleryCarouselIntervalMs?: number;
};

type Specialist = {
  _id?: string;
  slug?: string;
  name?: string;
  specialty?: string;
  shortBio?: string;
  focusAreas?: string[];
  ctaText?: string;
  ctaUrl?: string;
  useWhatsAppButton?: boolean;
  whatsAppNumber?: string;
  whatsAppMessage?: string;
  photoUrl?: string;
};

const business = await getBusinessInfo();
const about: AboutSection | null = await getAboutSection();
const services = (await getServices()) || [];
const specialists: Specialist[] = (await getSpecialists()) || [];

const generalWaNumber = resolveWhatsAppNumber(
  business?.whatsappCitasNumber,
  clinic.whatsappNumber
);
const specialistsWaNumber = resolveWhatsAppNumber(
  business?.whatsappSpecialistsNumber,
  generalWaNumber
);

const title = about?.title || "Nosotros";
const intro =
  about?.intro ||
  "Somos un centro integral de salud en Tulpetlac con atencion cercana, profesional y enfocada en resultados reales para cada paciente.";
const secondary =
  about?.secondary ||
  "Integramos podologia, psicologia, optica, quiropractica y dentista para ayudarte a cuidar tu bienestar en un solo lugar.";
const mainImage =
  about?.mainImageUrl ||
  "https://images.unsplash.com/photo-1579684385127-1ef15d508118?auto=format&fit=crop&w=1400&q=80";
const points = Array.isArray(about?.keyPoints) ? about.keyPoints.filter(Boolean).slice(0, 8) : [];
const gallery = Array.isArray(about?.galleryImageUrls) ? about.galleryImageUrls.filter(Boolean).slice(0, 6) : [];
const galleryAutoplayMsRaw = Number(about?.galleryCarouselIntervalMs);
const galleryAutoplayMs =
  Number.isFinite(galleryAutoplayMsRaw) && galleryAutoplayMsRaw >= 1200 && galleryAutoplayMsRaw <= 10000
    ? Math.round(galleryAutoplayMsRaw)
    : 2200;
const specialistsTitle = about?.specialistsTitle || "Nuestros especialistas";
const specialistsSubtitle =
  about?.specialistsSubtitle || "Conoce a las personas que atienden cada especialidad en nuestra clinica.";
const servicesTitle = about?.servicesTitle || "Especialidades que atendemos";
const servicesSubtitle = about?.servicesSubtitle || "Atendemos diferentes necesidades de salud con enfoque integral.";

function specialistLink(specialist: Specialist) {
  const shouldUseWhatsApp = specialist.useWhatsAppButton !== false;
  const waNumber = resolveWhatsAppNumber(
    specialist?.whatsAppNumber,
    specialistsWaNumber
  );

  if (shouldUseWhatsApp && waNumber) {
    const customReasonRaw = String(specialist.whatsAppMessage || "").trim();
    const reason = resolveWhatsAppReason(
      customReasonRaw || business?.whatsappSpecialistsMessage,
      "Quiero agendar con {especialista}.",
      {
        specialist: specialist.name || "este especialista",
        service: specialist.specialty || "Especialista",
        business: business?.name || clinic.name,
        problem: business?.whatsappQuickProblemDefault || "",
      }
    );
    return buildWhatsAppUrl(
      buildContactMessage({
        service: specialist.specialty || "Especialista",
        reason,
      }),
      waNumber
    );
  }

  return specialist.ctaUrl || "/agendar";
}

function specialistUsesWhatsApp(specialist: Specialist) {
  const waNumber = resolveWhatsAppNumber(
    specialist?.whatsAppNumber,
    specialistsWaNumber
  );
  return specialist.useWhatsAppButton !== false && Boolean(waNumber);
}

function specialistProfileHref(specialist: Specialist) {
  return `/especialistas/${encodeURIComponent((specialist.slug || specialist._id || "").trim())}`;
}
---

<Layout title={`Nosotros | ${business?.name || "Podologos Via Morelos"}`}>
  <Header />

  <main class="mx-auto max-w-6xl px-4 py-10">
    <section class="card-surface grid gap-8 rounded-3xl p-8 md:grid-cols-[1.1fr,0.9fr] md:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700 dark:text-sky-300">Conócenos</p>
        <h1 class="mt-2 text-4xl font-bold tracking-tight md:text-5xl">{title}</h1>
        <p class="mt-4 text-lg text-slate-700 dark:text-slate-300">{intro}</p>
        <p class="mt-4 text-lg text-slate-700 dark:text-slate-300">{secondary}</p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a class="btn-base btn-primary" href="/agendar">Agenda tu cita</a>
          <a class="btn-base btn-secondary" href="/servicios">Nuestros servicios</a>
        </div>
      </div>

      <div>
        <img class="h-80 w-full rounded-2xl object-cover ring-1 ring-slate-200 transition duration-300 hover:shadow-lg md:h-[31rem] dark:ring-slate-700" src={mainImage} alt="Equipo y atencion" loading="eager" />
      </div>
    </section>

    {points.length > 0 && (
      <section class="card-surface mt-8 rounded-3xl p-6">
        <h2 class="text-2xl font-bold tracking-tight">Por qué elegirnos</h2>
        <ul class="mt-4 grid gap-3 text-base text-slate-700 sm:grid-cols-2 dark:text-slate-300">
          {points.map((point) => (
            <li class="flex items-start gap-2"><span class="mt-1 h-2 w-2 rounded-full bg-sky-600"></span><span>{point}</span></li>
          ))}
        </ul>
      </section>
    )}

    <section class="card-surface mt-8 rounded-3xl p-6">
      <h2 class="text-2xl font-bold tracking-tight">{specialistsTitle}</h2>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{specialistsSubtitle}</p>

      {specialists.length === 0 ? (
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
          Pronto compartiremos los perfiles de nuestros especialistas.
        </div>
      ) : (
        <div class="mt-4 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {specialists.map((specialist) => (
            <article class="card-surface overflow-hidden rounded-2xl transition hover:-translate-y-0.5 hover:shadow-lg">
              <img
                class="h-52 w-full object-cover ring-1 ring-slate-200/70 transition duration-300 hover:opacity-95 dark:ring-slate-700/70"
                src={specialist.photoUrl || "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&w=1000&q=80"}
                alt={specialist.name || "Especialista"}
                loading="lazy"
              />
              <div class="p-4">
                <p class="text-lg font-bold">{specialist.name || "Especialista"}</p>
                <p class="mt-1 text-sm font-semibold text-sky-700 dark:text-sky-300">{specialist.specialty || "Especialidad"}</p>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{specialist.shortBio || "Perfil disponible pronto."}</p>

                {Array.isArray(specialist.focusAreas) && specialist.focusAreas.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {specialist.focusAreas.slice(0, 4).map((area) => (
                      <span class="rounded-full bg-sky-100 px-2.5 py-1 text-xs font-medium text-sky-700 dark:bg-sky-900/30 dark:text-sky-300">{area}</span>
                    ))}
                  </div>
                )}

                <div class="mt-4 grid grid-cols-2 gap-2">
                  <a
                    class="btn-base btn-primary w-full"
                    href={specialistLink(specialist)}
                    target={specialistUsesWhatsApp(specialist) ? "_blank" : undefined}
                    rel={specialistUsesWhatsApp(specialist) ? "noopener noreferrer" : undefined}
                  >
                    {specialist.ctaText || "Agendar"}
                  </a>
                  <a
                    class="btn-base btn-secondary w-full"
                    href={specialistProfileHref(specialist)}
                  >
                    Perfil
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <section class="card-surface mt-8 rounded-3xl p-6">
      <h2 class="text-2xl font-bold tracking-tight">{servicesTitle}</h2>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{servicesSubtitle}</p>
      <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service: { title?: string; short?: string }) => (
          <article class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900">
            <p class="text-base font-semibold">{service.title || "Servicio"}</p>
            {service.short && <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">{service.short}</p>}
          </article>
        ))}
      </div>
    </section>

    {gallery.length > 0 && (
      <section
        class="mt-8"
        data-about-page-gallery-carousel
        data-about-page-gallery-autoplay-ms={String(galleryAutoplayMs)}
      >
        <h2 class="text-2xl font-bold tracking-tight">Instalaciones y atencion</h2>
        <div class="relative mt-4">
          <button
            type="button"
            data-about-page-gallery-prev
            aria-label="Anterior"
            class={`absolute left-1 top-1/2 z-20 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-slate-200 bg-white/95 text-lg text-slate-700 shadow-sm transition hover:scale-105 hover:bg-white sm:left-2 md:left-3 md:h-10 md:w-10 md:text-xl lg:-left-10 xl:-left-14 dark:border-slate-700 dark:bg-slate-900/95 dark:text-slate-100 dark:hover:bg-slate-900 ${gallery.length > 1 ? "" : "hidden"}`}
          >
            <span aria-hidden="true">&lt;</span>
          </button>
          <button
            type="button"
            data-about-page-gallery-next
            aria-label="Siguiente"
            class={`absolute right-1 top-1/2 z-20 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-slate-200 bg-white/95 text-lg text-slate-700 shadow-sm transition hover:scale-105 hover:bg-white sm:right-2 md:right-3 md:h-10 md:w-10 md:text-xl lg:-right-10 xl:-right-14 dark:border-slate-700 dark:bg-slate-900/95 dark:text-slate-100 dark:hover:bg-slate-900 ${gallery.length > 1 ? "" : "hidden"}`}
          >
            <span aria-hidden="true">&gt;</span>
          </button>

          <div data-about-page-gallery-track class="no-scrollbar flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 [scrollbar-width:none]">
            {gallery.map((img, idx) => (
              <article data-about-page-gallery-item={idx} class="min-w-[88%] snap-start overflow-hidden rounded-2xl bg-white sm:min-w-[64%] md:min-w-[48%] lg:min-w-[34%] dark:bg-slate-950">
                <img class="h-52 w-full rounded-2xl object-cover ring-1 ring-slate-200 transition duration-300 hover:shadow-md dark:ring-slate-700" src={img} alt={`Foto ${idx + 1} de nosotros`} loading="lazy" />
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<script is:inline>
  const initLoopCarousel = ({ trackSelector, itemSelector, prevSelector, nextSelector, autoplayMs }) => {
    const track = document.querySelector(trackSelector);
    const prev = document.querySelector(prevSelector);
    const next = document.querySelector(nextSelector);
    if (!track || !prev || !next) return;

    let intervalId;
    let currentIndex = 0;

    const getItems = () => Array.from(track.querySelectorAll(itemSelector));

    const updateCurrentIndex = () => {
      const items = getItems();
      if (!items.length) return;
      currentIndex = items.reduce(
        (best, item, index) => {
          const dist = Math.abs(item.offsetLeft - track.scrollLeft);
          return dist < best.dist ? { index, dist } : best;
        },
        { index: 0, dist: Number.POSITIVE_INFINITY }
      ).index;
    };

    const updateControls = () => {
      const isSingleItem = getItems().length <= 1;
      prev.disabled = isSingleItem;
      next.disabled = isSingleItem;
      prev.classList.toggle("opacity-50", isSingleItem);
      prev.classList.toggle("cursor-not-allowed", isSingleItem);
      next.classList.toggle("opacity-50", isSingleItem);
      next.classList.toggle("cursor-not-allowed", isSingleItem);
    };

    const goToIndex = (index) => {
      const items = getItems();
      if (!items.length) return;
      const normalized = ((index % items.length) + items.length) % items.length;
      const target = items[normalized];
      if (!target) return;
      currentIndex = normalized;
      track.scrollTo({ left: target.offsetLeft, behavior: "smooth" });
      updateControls();
    };

    const move = (dir) => {
      const items = getItems();
      if (items.length <= 1) return;
      goToIndex(currentIndex + dir);
    };

    const stopAutoplay = () => {
      if (!intervalId) return;
      clearInterval(intervalId);
      intervalId = undefined;
    };

    const startAutoplay = () => {
      stopAutoplay();
      if (getItems().length <= 1) return;
      if (document.hidden) return;
      intervalId = setInterval(() => {
        updateCurrentIndex();
        move(1);
      }, autoplayMs);
    };

    prev.addEventListener("click", () => {
      updateCurrentIndex();
      move(-1);
      startAutoplay();
    });

    next.addEventListener("click", () => {
      updateCurrentIndex();
      move(1);
      startAutoplay();
    });

    track.addEventListener("scroll", () => {
      updateCurrentIndex();
      updateControls();
    }, { passive: true });
    track.addEventListener("mouseenter", stopAutoplay);
    track.addEventListener("mouseleave", startAutoplay);
    track.addEventListener("focusin", stopAutoplay);
    track.addEventListener("focusout", startAutoplay);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAutoplay();
      else startAutoplay();
    });

    updateCurrentIndex();
    updateControls();
    startAutoplay();
  };

  const aboutPageGalleryNode = document.querySelector("[data-about-page-gallery-carousel]");
  const aboutPageGalleryAutoplayFromDom = Number(
    aboutPageGalleryNode?.getAttribute("data-about-page-gallery-autoplay-ms") || "2200"
  );
  const aboutPageGalleryAutoplayFinal =
    Number.isFinite(aboutPageGalleryAutoplayFromDom) &&
    aboutPageGalleryAutoplayFromDom >= 1200 &&
    aboutPageGalleryAutoplayFromDom <= 10000
      ? aboutPageGalleryAutoplayFromDom
      : 2200;

  initLoopCarousel({
    trackSelector: "[data-about-page-gallery-track]",
    itemSelector: "[data-about-page-gallery-item]",
    prevSelector: "[data-about-page-gallery-prev]",
    nextSelector: "[data-about-page-gallery-next]",
    autoplayMs: aboutPageGalleryAutoplayFinal,
  });
</script>
